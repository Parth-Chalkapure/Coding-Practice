{
  "version": "2.0.0",
  "tasks": [
      {
          "label": "compile",
          "type": "shell",
          "command": "g++",
          "args": [
              "-std=c++17",
              "-o",
              "${fileBasenameNoExtension}",
              "${file}"
          ],
          "group": {
              "kind": "build",
              "isDefault": false
          }
      },
      {
          "label": "compile and run",
          "type": "shell",
          "command": "g++ -std=c++17 -o ${fileBasenameNoExtension} ${file}; if ($?) { Get-Content input.txt | .\\${fileBasenameNoExtension} > output.txt }",
          "group": {
              "kind": "build",
              "isDefault": true
          },
          "presentation": {
              "echo": true,
              "reveal": "silent",
              "focus": false,
              "panel": "shared",
              "showReuseMessage": false,
              "clear": false
          }
      }
  ]
}